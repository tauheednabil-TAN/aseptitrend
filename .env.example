# AseptiTrend environment variables
#
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# All secrets are read SERVER-SIDE ONLY and are never exposed to the browser.

# Anthropic API key — enables the "Generate investigation draft" AI feature.
# The app degrades gracefully if this is unset (AI drafting shows an "unavailable" state).
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for investigation drafts.
# Defaults to the latest Sonnet if unset.
ANTHROPIC_MODEL=claude-sonnet-5
