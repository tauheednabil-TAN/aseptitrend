# AseptiTrend environment variables
#
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# All secrets are read SERVER-SIDE ONLY and are never exposed to the browser.

# Google Gemini API key — enables the "Generate investigation draft" AI feature.
# Get one from Google AI Studio (https://aistudio.google.com/apikey).
# The app degrades gracefully if this is unset (AI drafting shows an "unavailable" state).
GEMINI_API_KEY=

# Optional: override the Gemini model used for investigation drafts.
# Defaults to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash
